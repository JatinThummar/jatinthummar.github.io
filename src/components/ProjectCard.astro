---
interface Props {
	href?: string;
	title: string;
	subtitle: string;
	description: string;
	class?: string;
}

const { href, title, subtitle, description, class: className = '' } = Astro.props;
const isLink = !!href;
const Tag = isLink ? 'a' : 'div';
const linkProps = isLink ? { href, target: '_blank', rel: 'noopener noreferrer' } : {};
---

<Tag
	{...linkProps}
	class:list={[
		'block rounded-xl bg-card-bg p-5',
		isLink && 'transition-all hover:scale-[1.01] active:scale-[0.99]',
		className,
	]}
>
	<h3 class="text-base font-semibold text-emphasis mb-1">{title}</h3>
	<p class="text-muted text-xs mb-2">{subtitle}</p>
	<p class="text-subtle text-sm leading-relaxed">{description}</p>
	<slot />
</Tag>
