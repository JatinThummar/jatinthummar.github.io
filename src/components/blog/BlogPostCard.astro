---
import { formatDate } from '../../utils/blog';

interface Props {
	post: {
		slug: string;
		title: string;
		description: string;
		publishDate: Date;
		readingTime: number;
		tags: string[];
	};
}

const { post } = Astro.props;
---

<a
	href={`/blog/${post.slug}`}
	class="block rounded-xl bg-card-bg p-5 transition-transform hover:scale-[1.01] active:scale-[0.99]"
>
	<h3 class="text-base font-semibold text-emphasis mb-1">{post.title}</h3>
	<div class="flex items-center gap-2 text-muted text-xs mb-2">
		<time datetime={post.publishDate.toISOString()}>{formatDate(post.publishDate)}</time>
		<span>&middot;</span>
		<span>{post.readingTime} min read</span>
	</div>
	<p class="text-subtle text-sm leading-relaxed mb-3">{post.description}</p>
	{post.tags.length > 0 && (
		<div class="flex flex-wrap gap-2">
			{post.tags.map((tag) => (
				<span class="text-xs text-muted">#{tag}</span>
			))}
		</div>
	)}
</a>
