---
import { formatDate } from '../../utils/blog';

interface Props {
	post: {
		slug: string;
		title: string;
		description: string;
		publishDate: Date;
		readingTime: number;
		tags: string[];
	};
}

const { post } = Astro.props;
---

<a
	href={`/blog/${post.slug}`}
	class="blog-card block rounded-xl border border-border p-4 transition-colors hover:border-muted active:scale-[0.99]"
>
	<div class="blog-card__header">
		<h3 class="text-base font-semibold text-emphasis">{post.title}</h3>
		<p class="text-muted text-xs mt-1 shrink-0">
			<time datetime={post.publishDate.toISOString()}>{formatDate(post.publishDate)}</time>
			<span class="blog-card__date-separator mx-1">&middot;</span>
			<span class="blog-card__read-time">{post.readingTime} min read</span>
		</p>
	</div>
	<p class="blog-card__description text-subtle text-sm leading-relaxed mt-2">{post.description}</p>
	{post.tags.length > 0 && (
		<div class="blog-card__tags flex flex-wrap gap-x-2 gap-y-1 mt-3">
			{post.tags.map((tag) => (
				<span class="text-xs text-muted">#{tag}</span>
			))}
		</div>
	)}
</a>
