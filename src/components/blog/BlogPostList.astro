---
import BlogPostCard from './BlogPostCard.astro';
import type { BlogPost } from '../../utils/blog';

interface Props {
	posts: BlogPost[];
	label: string;
	emptyMessage?: string;
}

const { posts, label, emptyMessage = 'No posts yet. Check back soon!' } = Astro.props;
---

{posts.length === 0 ? (
	<p class="text-muted text-sm">{emptyMessage}</p>
) : (
	<ul class="space-y-4" role="list" aria-label={label}>
		{posts.map((post) => (
			<li>
				<BlogPostCard post={post} />
			</li>
		))}
	</ul>
)}
