---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PrevNextNav from '../../components/blog/PrevNextNav.astro';
import RelatedPosts from '../../components/blog/RelatedPosts.astro';
import { fetchPosts, formatDate, getRelatedPosts } from '../../utils/blog';
import type { BlogPost } from '../../utils/blog';

export const getStaticPaths: GetStaticPaths = async () => {
	const posts = await fetchPosts();
	return posts.map((post, index) => ({
		params: { slug: post.slug },
		props: {
			post,
			prevPost: index < posts.length - 1 ? { slug: posts[index + 1].slug, title: posts[index + 1].title } : undefined,
			nextPost: index > 0 ? { slug: posts[index - 1].slug, title: posts[index - 1].title } : undefined,
			relatedPosts: getRelatedPosts(post, posts),
		},
	}));
};

interface Props {
	post: BlogPost;
	prevPost?: { slug: string; title: string };
	nextPost?: { slug: string; title: string };
	relatedPosts: BlogPost[];
}

const { post, prevPost, nextPost, relatedPosts } = Astro.props;
const siteUrl = 'https://jatinthummar.github.io';

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "BlogPosting",
	"headline": post.title,
	"description": post.description,
	"image": `${siteUrl}/og/${post.slug}.png`,
	"datePublished": post.publishDate.toISOString(),
	"dateModified": (post.updatedDate ?? post.publishDate).toISOString(),
	"author": {
		"@type": "Person",
		"name": "Jatin Thummar",
		"url": siteUrl,
	},
	"url": `${siteUrl}/blog/${post.slug}`,
	"mainEntityOfPage": {
		"@type": "WebPage",
		"@id": `${siteUrl}/blog/${post.slug}`,
	},
};
---

<BaseLayout
	title={`${post.title} — Jatin Thummar`}
	description={post.description}
	canonicalUrl={`${siteUrl}/blog/${post.slug}`}
	ogType="article"
	ogImage={`/og/${post.slug}.png`}
	jsonLd={jsonLd}
>
	<main class="max-w-xl w-full mx-auto py-20">
		<a href="/blog" class="inline-flex items-center gap-1.5 text-muted hover:text-emphasis transition text-sm mb-10">
			<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<line x1="19" y1="12" x2="5" y2="12" />
				<polyline points="12 19 5 12 12 5" />
			</svg>
			Back to blog
		</a>

		<article>
			<header class="mb-8">
				<h1 class="text-3xl font-bold tracking-tight mb-3">{post.title}</h1>
				<p class="text-muted text-xs">
					<time datetime={post.publishDate.toISOString()}>{formatDate(post.publishDate)}</time>
					<span class="mx-1">&middot;</span>
					<span>{post.readingTime} min read</span>
				</p>
				{post.tags.length > 0 && (
					<div class="flex flex-wrap gap-x-2 gap-y-1 mt-2">
						{post.tags.map((tag) => (
							<a href={`/blog/tag/${tag}`} class="text-xs text-muted hover:text-emphasis transition">#{tag}</a>
						))}
					</div>
				)}
				<div class="flex items-center gap-2 mt-4 pt-3 border-t border-dashed border-border justify-end">
					<button
						id="share-btn"
						type="button"
						class="inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-full bg-tag-bg text-tag-text text-sm transition-colors hover:text-emphasis active:scale-[0.98]"
						aria-label="Share this post"
						data-title={post.title}
						data-url={`${siteUrl}/blog/${post.slug}`}
					>
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<circle cx="18" cy="5" r="3" />
							<circle cx="6" cy="12" r="3" />
							<circle cx="18" cy="19" r="3" />
							<line x1="8.59" y1="13.51" x2="15.42" y2="17.49" />
							<line x1="15.41" y1="6.51" x2="8.59" y2="10.49" />
						</svg>
						<span id="share-text">Share</span>
					</button>
					<a
						href={`https://x.com/intent/tweet?text=${encodeURIComponent(post.title)}&url=${encodeURIComponent(`${siteUrl}/blog/${post.slug}`)}`}
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-tag-bg text-tag-text transition-colors hover:text-emphasis"
						aria-label="Share on X"
					>
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="15" height="15" fill="currentColor" aria-hidden="true">
							<path d="M389.2 48h70.6L305.6 224.2L487 464H345L233.7 318.6L106.5 464H35.8l164.9-188.5L26.8 48h145.6l100.5 132.9zm-24.8 373.8h39.1L151.1 88h-42z" />
						</svg>
					</a>
					<a
						href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(`${siteUrl}/blog/${post.slug}`)}`}
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-tag-bg text-tag-text transition-colors hover:text-emphasis"
						aria-label="Share on LinkedIn"
					>
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 448" width="15" height="15" fill="currentColor" aria-hidden="true">
							<path d="M100.28 448H7.4V148.9h92.88zM53.79 108.1C24.09 108.1 0 83.5 0 53.8a53.79 53.79 0 0 1 107.58 0c0 29.7-24.1 54.3-53.79 54.3M447.9 448h-92.68V302.4c0-34.7-.7-79.2-48.29-79.2c-48.29 0-55.69 37.7-55.69 76.7V448h-92.78V148.9h89.08v40.8h1.3c12.4-23.5 42.69-48.3 87.88-48.3c94 0 111.28 61.9 111.28 142.3V448z" />
						</svg>
					</a>
				</div>
			</header>

			<div class="prose prose-custom max-w-none">
				<post.Content />
			</div>
		</article>

		<RelatedPosts posts={relatedPosts} />
		<PrevNextNav prev={prevPost} next={nextPost} />
	</main>

	<script>
		const shareBtn = document.getElementById('share-btn')!;
		const shareText = document.getElementById('share-text')!;
		const title = shareBtn.dataset.title!;
		const url = shareBtn.dataset.url!;

		shareBtn.addEventListener('click', async () => {
			if (navigator.share) {
				try {
					await navigator.share({ title, url });
				} catch {
					// user cancelled — do nothing
				}
			} else {
				await navigator.clipboard.writeText(url);
				shareText.textContent = 'Link copied!';
				setTimeout(() => {
					shareText.textContent = 'Share';
				}, 2000);
			}
		});
	</script>
</BaseLayout>
