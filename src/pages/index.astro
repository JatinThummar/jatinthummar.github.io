---
import { Image } from 'astro:assets';
import avatarColor from '../assets/avatar-color.png';
import avatarOutline from '../assets/avatar-outline.png';
import '../styles/global.css';

import Separator from '../components/Separator.astro';
import BookmarkCard from '../components/BookmarkCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SocialButton from '../components/SocialButton.astro';

const title = 'Jatin Thummar — Frontend Engineer';
const description = 'Frontend Engineer specializing in scalable cross-platform applications. Building production-grade apps for Android, iOS & Web with well-architected frontends using Expo, React Native, and Next.js.';
const siteUrl = 'https://jatinthummar.github.io';
const canonicalUrl = siteUrl;

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "Person",
	"name": "Jatin Thummar",
	"jobTitle": "Frontend Engineer",
	"url": siteUrl,
	"description": description,
	"knowsAbout": [
		"Cross-Platform App Development",
		"Frontend Architecture",
		"React Native",
		"Expo",
		"TypeScript",
		"Next.js",
		"Vite",
		"Scalable Frontend Systems",
		"Mobile App Development"
	],
	"image": `${siteUrl}/og-image.png`,
	"sameAs": [
		"https://github.com/JatinThummar",
		"https://x.com/jatinthummarx",
		"https://in.linkedin.com/in/jatinthumma"
	]
};
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />

		<!-- Theme -->
		<meta name="theme-color" content="#161618" />
		<meta name="msapplication-TileColor" content="#161618" />

		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />
		<meta name="author" content="Jatin Thummar" />
		<link rel="canonical" href={canonicalUrl} />
		<meta name="robots" content="index, follow" />
		<link rel="sitemap" href="/sitemap-index.xml" />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={siteUrl} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:site_name" content="Jatin Thummar" />
		<meta property="og:locale" content="en_US" />
		<meta property="og:image" content={`${siteUrl}/og-image.png`} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content="Jatin Thummar — Frontend Engineer" />

		<!-- Twitter / X -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:image" content={`${siteUrl}/og-image.png`} />
		<meta name="twitter:url" content={siteUrl} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:creator" content="@jatinthummarx" />

		<!-- JSON-LD Structured Data -->
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

		<!-- FOUC prevention: apply saved theme before first paint -->
		<script is:inline>
			(function () {
				var stored = localStorage.getItem('theme');
				if (stored === 'light') {
					document.documentElement.classList.add('light');
				}
			})();
		</script>
	</head>
	<body class="min-h-screen bg-surface text-on-surface flex items-center justify-center px-6">
		<!-- Theme toggle -->
		<button
			id="theme-toggle"
			type="button"
			class="fixed top-6 right-6 z-50 inline-flex items-center justify-center w-11 h-11 rounded-xl bg-btn-icon-bg text-btn-icon-text hover:bg-btn-icon-hover-bg hover:text-btn-icon-hover-text transition hover:scale-105 active:scale-95"
			aria-label="Toggle theme"
		>
			<svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<circle cx="12" cy="12" r="5" />
				<line x1="12" y1="1" x2="12" y2="3" />
				<line x1="12" y1="21" x2="12" y2="23" />
				<line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
				<line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
				<line x1="1" y1="12" x2="3" y2="12" />
				<line x1="21" y1="12" x2="23" y2="12" />
				<line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
				<line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
			</svg>
			<svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden" aria-hidden="true">
				<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
			</svg>
		</button>

		<main class="max-w-xl w-full py-20">
			<!-- Avatar + Heading: stacked on mobile, side by side on sm+ -->
			<div class="flex flex-col sm:flex-row sm:items-center gap-5 mb-8">
				<div class="relative w-37.5 h-37.5 shrink-0 group">
					<Image
						src={avatarOutline}
						alt="Jatin Thummar"
						width={192}
						height={192}
						class="absolute inset-0 rounded-2xl transition-opacity duration-300 ease-in-out opacity-100 group-hover:opacity-0 group-focus-within:opacity-0"
						quality={90}
						loading="eager"
						fetchpriority="high"
					/>
					<Image
						src={avatarColor}
						alt=""
						width={192}
						height={192}
						class="absolute inset-0 rounded-2xl transition-opacity duration-300 ease-in-out opacity-0 group-hover:opacity-100 group-focus-within:opacity-100"
						quality={90}
						loading="eager"
						fetchpriority="low"
					/>
				</div>
				<div>
					<p class="text-muted text-lg mb-1">Hey there!</p>
					<h1 class="text-4xl font-bold tracking-tight">
						I'm Jatin Thummar
					</h1>
				</div>
			</div>

			<p class="text-subtle text-lg leading-relaxed mb-8">
				Frontend Engineer building scalable cross-platform apps for
				<span class="text-emphasis font-medium">Android</span>,
				<span class="text-emphasis font-medium">iOS</span> &
				<span class="text-emphasis font-medium">Web</span> with
				<span class="text-emphasis font-medium">Expo</span> &
				<span class="text-emphasis font-medium">React Native</span>.
			</p>

			<div class="flex flex-wrap gap-2 mb-10">
				{['React Native', 'Expo', 'TypeScript', 'JavaScript', 'Next.js', 'Tailwind CSS'].map(tech => (
					<span class="px-3 py-1 text-sm rounded-full bg-tag-bg text-tag-text">
						{tech}
					</span>
				))}
			</div>

			<nav class="flex flex-col sm:flex-row sm:items-center gap-4" aria-label="Social links">
				<button
					id="reach-out-btn"
					type="button"
					class="inline-flex items-center justify-center gap-2.5 px-6 py-3.5 bg-btn-primary-bg text-btn-primary-text font-semibold text-base rounded-xl transition hover:scale-105 active:scale-95 hover:bg-btn-primary-hover-bg hover:text-btn-primary-hover-text active:bg-btn-primary-active-bg active:text-btn-primary-hover-text sm:py-2.5 sm:px-5 cursor-pointer"
				>
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
						<path d="M8 5v14l11-7z" />
					</svg>
					Reach out
				</button>
				<div class="flex gap-3">
					<SocialButton href="https://github.com/JatinThummar" label="GitHub">
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 496" width="22" height="22" fill="currentColor" aria-hidden="true">
							<path d="M165.9 397.4c0 2-2.3 3.6-5.2 3.6c-3.3.3-5.6-1.3-5.6-3.6c0-2 2.3-3.6 5.2-3.6c3-.3 5.6 1.3 5.6 3.6m-31.1-4.5c-.7 2 1.3 4.3 4.3 4.9c2.6 1 5.6 0 6.2-2s-1.3-4.3-4.3-5.2c-2.6-.7-5.5.3-6.2 2.3m44.2-1.7c-2.9.7-4.9 2.6-4.6 4.9c.3 2 2.9 3.3 5.9 2.6c2.9-.7 4.9-2.6 4.6-4.6c-.3-1.9-3-3.2-5.9-2.9M244.8 8C106.1 8 0 113.3 0 252c0 110.9 69.8 205.8 169.5 239.2c12.8 2.3 17.3-5.6 17.3-12.1c0-6.2-.3-40.4-.3-61.4c0 0-70 15-84.7-29.8c0 0-11.4-29.1-27.8-36.6c0 0-22.9-15.7 1.6-15.4c0 0 24.9 2 38.6 25.8c21.9 38.6 58.6 27.5 72.9 20.9c2.3-16 8.8-27.1 16-33.7c-55.9-6.2-112.3-14.3-112.3-110.5c0-27.5 7.6-41.3 23.6-58.9c-2.6-6.5-11.1-33.3 2.6-67.9c20.9-6.5 69 27 69 27c20-5.6 41.5-8.5 62.8-8.5s42.8 2.9 62.8 8.5c0 0 48.1-33.6 69-27c13.7 34.7 5.2 61.4 2.6 67.9c16 17.7 25.8 31.5 25.8 58.9c0 96.5-58.9 104.2-114.8 110.5c9.2 7.9 17 22.9 17 46.4c0 33.7-.3 75.4-.3 83.6c0 6.5 4.6 14.4 17.3 12.1C428.2 457.8 496 362.9 496 252C496 113.3 383.5 8 244.8 8M97.2 352.9c-1.3 1-1 3.3.7 5.2c1.6 1.6 3.9 2.3 5.2 1c1.3-1 1-3.3-.7-5.2c-1.6-1.6-3.9-2.3-5.2-1m-10.8-8.1c-.7 1.3.3 2.9 2.3 3.9c1.6 1 3.6.7 4.3-.7c.7-1.3-.3-2.9-2.3-3.9c-2-.6-3.6-.3-4.3.7m32.4 35.6c-1.6 1.3-1 4.3 1.3 6.2c2.3 2.3 5.2 2.6 6.5 1c1.3-1.3.7-4.3-1.3-6.2c-2.2-2.3-5.2-2.6-6.5-1m-11.4-14.7c-1.6 1-1.6 3.6 0 5.9s4.3 3.3 5.6 2.3c1.6-1.3 1.6-3.9 0-6.2c-1.4-2.3-4-3.3-5.6-2" />
						</svg>
					</SocialButton>
					<SocialButton href="https://in.linkedin.com/in/jatinthumma" label="LinkedIn">
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 448" width="22" height="22" fill="currentColor" aria-hidden="true">
							<path d="M100.28 448H7.4V148.9h92.88zM53.79 108.1C24.09 108.1 0 83.5 0 53.8a53.79 53.79 0 0 1 107.58 0c0 29.7-24.1 54.3-53.79 54.3M447.9 448h-92.68V302.4c0-34.7-.7-79.2-48.29-79.2c-48.29 0-55.69 37.7-55.69 76.7V448h-92.78V148.9h89.08v40.8h1.3c12.4-23.5 42.69-48.3 87.88-48.3c94 0 111.28 61.9 111.28 142.3V448z" />
						</svg>
					</SocialButton>
					<SocialButton href="https://x.com/jatinthummarx" label="X (Twitter)">
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="22" height="22" fill="currentColor" aria-hidden="true">
							<path d="M389.2 48h70.6L305.6 224.2L487 464H345L233.7 318.6L106.5 464H35.8l164.9-188.5L26.8 48h145.6l100.5 132.9zm-24.8 373.8h39.1L151.1 88h-42z" />
						</svg>
					</SocialButton>
				</div>
			</nav>

			<Separator class="my-12" />

			<!-- Currently -->
			<section aria-labelledby="currently-heading" class="mb-12">
				<h2 id="currently-heading" class="text-xl font-bold mb-4">Currently</h2>
				<p class="text-subtle text-sm leading-relaxed mb-4">
					Frontend Engineer & Mobile App Developer at The Korean Fashion — building and scaling the mobile app, shipping new features, improving performance, and refining the developer experience.
				</p>
				<BookmarkCard
					href="https://www.thekoreanfashion.com/"
					title="The Korean Fashion"
					description="Clothing and Jewelry Online Shop"
					domain="thekoreanfashion.com"
					logoSrc="/logos/thekoreanfashion.png"
					logoAlt="The Korean Fashion"
				/>
			</section>

			<Separator />

			<!-- Work & Side Projects -->
			<section aria-labelledby="projects-heading" class="mt-12">
				<h2 id="projects-heading" class="text-xl font-bold mb-6">Work & Side Projects</h2>
				<ProjectCard
					href="https://flipbitz.netlify.app/web/"
					title="FlipBitz — Feed App"
					subtitle="Personal Project"
					description="Cross-platform feed app for iOS, Android & Web. Browse real-time news, follow curated feeds, and personalize your experience with dynamic color themes and light/dark mode."
				/>
				<ProjectCard
					class="mt-4"
					title="LEO Mobile App Builder"
					subtitle="Lead Developer · Softpulse Infotech · 2023 – 2024"
					description="No-code mobile app builder for Shopify stores. Merchants can create and publish their own e-commerce app to iOS and Android — no coding required."
				>
					<BookmarkCard
						href="https://leoapps.io/"
						title="LEO Shopify Apps"
						description="Mobile App Builder, Preloader & Order Editing"
						domain="leoapps.io"
						logoSrc="/logos/leoapps.png"
						logoAlt="LEO Apps"
						compact
					/>
				</ProjectCard>
				<ProjectCard
					class="mt-4"
					title="As a Man Thinketh"
					subtitle="Personal Project"
					description="Static reading experience for James Allen's classic book, translated into multiple languages including English, Gujarati, and Hindi. Deployed on GitHub Pages."
				>
					<BookmarkCard
						href="https://jatinthummar.github.io/thinketh/"
						title="As a Man Thinketh"
						description="Read the classic by James Allen"
						domain="jatinthummar.github.io"
						logoSrc="/logos/thinketh.png"
						logoAlt="As a Man Thinketh"
						compact
					/>
				</ProjectCard>
			</section>
		</main>

		<!-- Email modal -->
		<div
			id="email-modal"
			class="fixed inset-0 z-50 flex items-center justify-center px-6 opacity-0 pointer-events-none transition-opacity duration-200"
			aria-hidden="true"
			role="dialog"
			aria-labelledby="modal-heading"
			aria-modal="true"
		>
			<div id="email-backdrop" class="absolute inset-0 bg-black/60"></div>
			<div id="modal-panel" class="relative w-full max-w-sm rounded-2xl bg-modal-bg p-6 shadow-2xl">
				<div class="flex items-center justify-between mb-5">
					<p id="modal-heading" class="text-xl font-bold text-modal-text">Let's Connect!</p>
					<button
						id="modal-close"
						type="button"
						class="inline-flex items-center justify-center w-8 h-8 rounded-lg text-muted hover:text-modal-text transition-colors"
						aria-label="Close dialog"
					>
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<line x1="18" y1="6" x2="6" y2="18" />
							<line x1="6" y1="6" x2="18" y2="18" />
						</svg>
					</button>
				</div>
				<p class="font-mono font-semibold text-modal-text text-base sm:text-lg break-all mb-4">thummarjatin1208@gmail.com</p>
				<button
					id="copy-email-btn"
					type="button"
					class="w-full inline-flex items-center justify-center gap-2 px-4 py-3 bg-btn-copy-bg text-btn-copy-text font-semibold text-sm rounded-xl transition-transform hover:scale-[1.02] active:scale-[0.98] cursor-pointer"
				>
					<svg id="icon-clipboard" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
						<path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
					</svg>
					<svg id="icon-check" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden" aria-hidden="true">
						<polyline points="20 6 9 17 4 12" />
					</svg>
					<span id="copy-text">Copy Email</span>
				</button>
			</div>
		</div>

		<!-- Theme toggle + email modal logic -->
		<script>
			// Theme toggle
			const toggle = document.getElementById('theme-toggle')!;
			const iconSun = document.getElementById('icon-sun')!;
			const iconMoon = document.getElementById('icon-moon')!;

			function updateIcons() {
				const isLight = document.documentElement.classList.contains('light');
				iconSun.classList.toggle('hidden', isLight);
				iconSun.classList.toggle('block', !isLight);
				iconMoon.classList.toggle('hidden', !isLight);
				iconMoon.classList.toggle('block', isLight);
			}

			updateIcons();

			toggle.addEventListener('click', () => {
				const html = document.documentElement;
				const isCurrentlyLight = html.classList.contains('light');

				if (isCurrentlyLight) {
					html.classList.remove('light');
					localStorage.setItem('theme', 'dark');
				} else {
					html.classList.add('light');
					localStorage.setItem('theme', 'light');
				}

				updateIcons();

				document.querySelector('meta[name="theme-color"]')!
					.setAttribute('content', isCurrentlyLight ? '#161618' : '#ffffff');
			});

			// Email modal
			const modal = document.getElementById('email-modal')!;
			const panel = document.getElementById('modal-panel')!;
			const reachOutBtn = document.getElementById('reach-out-btn')!;
			const modalClose = document.getElementById('modal-close')!;
			const backdrop = document.getElementById('email-backdrop')!;
			const copyBtn = document.getElementById('copy-email-btn')!;
			const iconClipboard = document.getElementById('icon-clipboard')!;
			const iconCheck = document.getElementById('icon-check')!;
			const copyText = document.getElementById('copy-text')!;

			function openModal() {
				modal.classList.remove('opacity-0', 'pointer-events-none');
				modal.classList.add('opacity-100');
				modal.setAttribute('aria-hidden', 'false');
				copyBtn.focus();
			}

			function closeModal() {
				modal.classList.remove('opacity-100');
				modal.classList.add('opacity-0', 'pointer-events-none');
				modal.setAttribute('aria-hidden', 'true');
				reachOutBtn.focus();
			}

			reachOutBtn.addEventListener('click', openModal);
			modalClose.addEventListener('click', closeModal);
			backdrop.addEventListener('click', closeModal);

			document.addEventListener('keydown', (e) => {
				if (e.key === 'Escape' && !modal.classList.contains('pointer-events-none')) {
					closeModal();
				}
				// Focus trap within modal
				if (e.key === 'Tab' && !modal.classList.contains('pointer-events-none')) {
					const focusable = panel.querySelectorAll('button');
					const first = focusable[0];
					const last = focusable[focusable.length - 1];
					if (e.shiftKey && document.activeElement === first) {
						e.preventDefault();
						last.focus();
					} else if (!e.shiftKey && document.activeElement === last) {
						e.preventDefault();
						first.focus();
					}
				}
			});

			copyBtn.addEventListener('click', () => {
				navigator.clipboard.writeText('thummarjatin1208@gmail.com').then(() => {
					iconClipboard.classList.add('hidden');
					iconCheck.classList.remove('hidden');
					copyText.textContent = 'Copied!';

					setTimeout(() => {
						iconClipboard.classList.remove('hidden');
						iconCheck.classList.add('hidden');
						copyText.textContent = 'Copy Email';
					}, 2000);
				}).catch(() => {
					copyText.textContent = 'Failed to copy';
					setTimeout(() => {
						copyText.textContent = 'Copy Email';
					}, 2000);
				});
			});
		</script>
	</body>
</html>
