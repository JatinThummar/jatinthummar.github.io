---
import { Image } from 'astro:assets';
import avatarColor from '../assets/avatar-color.png';
import avatarOutline from '../assets/avatar-outline.png';
import '../styles/global.css';

const title = 'Jatin Thummar — Frontend Engineer';
const description = 'Frontend Engineer specializing in scalable cross-platform applications. Building production-grade apps for Android, iOS & Web with well-architected frontends using Expo, React Native, and Next.js.';
const siteUrl = 'https://jatinthummar.github.io';
const canonicalUrl = siteUrl;

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "Person",
	"name": "Jatin Thummar",
	"jobTitle": "Frontend Engineer",
	"url": siteUrl,
	"description": description,
	"knowsAbout": [
		"Cross-Platform App Development",
		"Frontend Architecture",
		"React Native",
		"Expo",
		"TypeScript",
		"Next.js",
		"Vite",
		"Scalable Frontend Systems",
		"Mobile App Development"
	],
	"image": `${siteUrl}/og-image.png`,
	"sameAs": [
		"https://github.com/JatinThummar",
		"https://x.com/jatinthummarx",
		"https://in.linkedin.com/in/jatinthumma"
	]
};
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />

		<!-- Theme -->
		<meta name="theme-color" content="#09090b" />
		<meta name="msapplication-TileColor" content="#09090b" />

		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />
		<meta name="author" content="Jatin Thummar" />
		<link rel="canonical" href={canonicalUrl} />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={siteUrl} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:site_name" content="Jatin Thummar" />
		<meta property="og:locale" content="en_US" />
		<meta property="og:image" content={`${siteUrl}/og-image.png`} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content="Jatin Thummar — Frontend Engineer" />

		<!-- Twitter / X -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:image" content={`${siteUrl}/og-image.png`} />
		<meta name="twitter:url" content={siteUrl} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:creator" content="@jatinthummarx" />

		<!-- JSON-LD Structured Data -->
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
	</head>
	<body class="min-h-screen bg-zinc-950 text-zinc-100 flex items-center justify-center px-6">
		<main class="max-w-xl w-full py-20">
			<!-- Avatar + Heading side by side -->
			<div class="flex items-center gap-5 mb-8">
				<div class="avatar shrink-0">
					<Image
						src={avatarOutline}
						alt="Jatin Thummar"
						width={192}
						height={192}
						class="rounded-2xl"
						quality={90}
						loading="eager"
						fetchpriority="high"
					/>
					<Image
						src={avatarColor}
						alt=""
						width={192}
						height={192}
						class="rounded-2xl"
						quality={90}
						loading="eager"
						fetchpriority="low"
					/>
				</div>
				<div>
					<p class="text-zinc-400 text-lg mb-1">Hey there!</p>
					<h1 class="text-4xl font-bold tracking-tight">
						I'm Jatin Thummar
					</h1>
				</div>
			</div>

			<p class="text-zinc-300 text-lg leading-relaxed mb-8">
				Frontend Engineer building scalable cross-platform apps for
				<span class="text-white font-medium">Android</span>,
				<span class="text-white font-medium">iOS</span> &
				<span class="text-white font-medium">Web</span> with
				<span class="text-white font-medium">Expo</span> &
				<span class="text-white font-medium">React Native</span>.
			</p>

			<div class="flex flex-wrap gap-2 mb-10">
				{['React Native', 'Expo', 'TypeScript', 'JavaScript', 'Next.js', 'Tailwind CSS'].map(tech => (
					<span class="px-3 py-1 text-sm rounded-full bg-zinc-800 text-zinc-300 border border-zinc-700">
						{tech}
					</span>
				))}
			</div>

			<nav class="flex gap-3 items-center flex-wrap" aria-label="Social links">
				<!-- <a
					href="https://flipbitzz.expo.app/"
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex items-center gap-2 px-5 py-2.5 bg-zinc-100 text-zinc-900 font-medium rounded-full hover:bg-white transition-colors"
					aria-label="FlipBitz app"
				>
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<path d="m5 12 7-7 7 7" /><path d="M12 19V5" />
					</svg>
					FlipBitz
				</a> -->
				<a
					href="https://github.com/JatinThummar"
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex items-center justify-center w-11 h-11 rounded-xl bg-zinc-800 text-zinc-300 hover:bg-zinc-700 hover:text-white transition-colors border border-zinc-700"
					aria-label="GitHub"
				>
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 496" width="20" height="20" fill="currentColor" aria-hidden="true">
						<path d="M165.9 397.4c0 2-2.3 3.6-5.2 3.6c-3.3.3-5.6-1.3-5.6-3.6c0-2 2.3-3.6 5.2-3.6c3-.3 5.6 1.3 5.6 3.6m-31.1-4.5c-.7 2 1.3 4.3 4.3 4.9c2.6 1 5.6 0 6.2-2s-1.3-4.3-4.3-5.2c-2.6-.7-5.5.3-6.2 2.3m44.2-1.7c-2.9.7-4.9 2.6-4.6 4.9c.3 2 2.9 3.3 5.9 2.6c2.9-.7 4.9-2.6 4.6-4.6c-.3-1.9-3-3.2-5.9-2.9M244.8 8C106.1 8 0 113.3 0 252c0 110.9 69.8 205.8 169.5 239.2c12.8 2.3 17.3-5.6 17.3-12.1c0-6.2-.3-40.4-.3-61.4c0 0-70 15-84.7-29.8c0 0-11.4-29.1-27.8-36.6c0 0-22.9-15.7 1.6-15.4c0 0 24.9 2 38.6 25.8c21.9 38.6 58.6 27.5 72.9 20.9c2.3-16 8.8-27.1 16-33.7c-55.9-6.2-112.3-14.3-112.3-110.5c0-27.5 7.6-41.3 23.6-58.9c-2.6-6.5-11.1-33.3 2.6-67.9c20.9-6.5 69 27 69 27c20-5.6 41.5-8.5 62.8-8.5s42.8 2.9 62.8 8.5c0 0 48.1-33.6 69-27c13.7 34.7 5.2 61.4 2.6 67.9c16 17.7 25.8 31.5 25.8 58.9c0 96.5-58.9 104.2-114.8 110.5c9.2 7.9 17 22.9 17 46.4c0 33.7-.3 75.4-.3 83.6c0 6.5 4.6 14.4 17.3 12.1C428.2 457.8 496 362.9 496 252C496 113.3 383.5 8 244.8 8M97.2 352.9c-1.3 1-1 3.3.7 5.2c1.6 1.6 3.9 2.3 5.2 1c1.3-1 1-3.3-.7-5.2c-1.6-1.6-3.9-2.3-5.2-1m-10.8-8.1c-.7 1.3.3 2.9 2.3 3.9c1.6 1 3.6.7 4.3-.7c.7-1.3-.3-2.9-2.3-3.9c-2-.6-3.6-.3-4.3.7m32.4 35.6c-1.6 1.3-1 4.3 1.3 6.2c2.3 2.3 5.2 2.6 6.5 1c1.3-1.3.7-4.3-1.3-6.2c-2.2-2.3-5.2-2.6-6.5-1m-11.4-14.7c-1.6 1-1.6 3.6 0 5.9s4.3 3.3 5.6 2.3c1.6-1.3 1.6-3.9 0-6.2c-1.4-2.3-4-3.3-5.6-2" />
					</svg>
				</a>
				<a
					href="https://x.com/jatinthummarx"
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex items-center justify-center w-11 h-11 rounded-xl bg-zinc-800 text-zinc-300 hover:bg-zinc-700 hover:text-white transition-colors border border-zinc-700"
					aria-label="X (Twitter)"
				>
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="20" height="20" fill="currentColor" aria-hidden="true">
						<path d="M389.2 48h70.6L305.6 224.2L487 464H345L233.7 318.6L106.5 464H35.8l164.9-188.5L26.8 48h145.6l100.5 132.9zm-24.8 373.8h39.1L151.1 88h-42z" />
					</svg>
				</a>
				<a
					href="https://in.linkedin.com/in/jatinthumma"
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex items-center justify-center w-11 h-11 rounded-xl bg-zinc-800 text-zinc-300 hover:bg-zinc-700 hover:text-white transition-colors border border-zinc-700"
					aria-label="LinkedIn"
				>
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 448" width="20" height="20" fill="currentColor" aria-hidden="true">
						<path d="M100.28 448H7.4V148.9h92.88zM53.79 108.1C24.09 108.1 0 83.5 0 53.8a53.79 53.79 0 0 1 107.58 0c0 29.7-24.1 54.3-53.79 54.3M447.9 448h-92.68V302.4c0-34.7-.7-79.2-48.29-79.2c-48.29 0-55.69 37.7-55.69 76.7V448h-92.78V148.9h89.08v40.8h1.3c12.4-23.5 42.69-48.3 87.88-48.3c94 0 111.28 61.9 111.28 142.3V448z" />
					</svg>
				</a>
			</nav>
		</main>
	</body>
</html>
